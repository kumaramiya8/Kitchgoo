# ─── Kitchgoo — Environment Variables ────────────────────────
# Copy this file to .env and fill in your Supabase credentials.
#
# Setup steps:
#   1. Go to https://supabase.com and create a free account
#   2. Create a new project (choose any region, set a DB password)
#   3. Once the project is ready, open SQL Editor and run supabase-schema.sql
#   4. Go to Project Settings → API
#   5. Copy the "Project URL" and "anon public" key below
#   6. Rename this file to .env and restart the dev server

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
